# ============================================================
# 节能阀 Cost Valve - 环境变量配置示例
# 复制此文件为 .env 并修改对应值
# ============================================================

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# 数据库路径
DB_PATH=./data/cost_valve.db

# API Key（单用户模式，设置后需要在请求头 X-API-Key 中传入）
# 留空则无需认证（本地开发用）
COST_VALVE_API_KEY=

# ============================================================
# 缓存配置
# ============================================================
CACHE_ENABLED=true
EXACT_CACHE_TTL=3600  # 精确缓存过期时间（秒），默认1小时

# ============================================================
# Prompt 优化配置
# ============================================================
PROMPT_OPTIMIZE_ENABLED=true
PROMPT_MAX_TOKENS=4096

# ============================================================
# 模型提供商配置（配置后可直接使用，无需每次传 Header）
# ============================================================

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 智谱 GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# 通义千问（阿里云）
ALIYUN_API_KEY=
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
ALIYUN_MODEL=qwen-turbo

# 豆包（字节跳动）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_MODEL=gemini-3-flash

# 通用 OpenAI 兼容提供商
GENERIC_API_KEY=
GENERIC_BASE_URL=
GENERIC_MODEL=
